# ── Ascend Concierge Copilot · configuration ────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env (it's gitignored).
#
# The app runs fully offline with the built-in `mock` provider, so you can demo
# with zero keys. Add a key below to route to real models.

# Single key, many models (recommended): GLM, DeepSeek, Claude, GPT, Gemini...
OPENROUTER_API_KEY=

# Optional native providers (used only if you prefer them over OpenRouter)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Provider to use when a key is present: openrouter | anthropic | mock
# `mock` forces the offline deterministic provider regardless of keys.
COPILOT_PROVIDER=mock

# Hard ceiling on spend (USD) for a single process. The gateway refuses calls
# whose projected cost would cross this. Your "hit usage limits" guardrail.
COPILOT_BUDGET_USD=5.00

# Where per-call traces (cost, latency, tokens, model) are written.
COPILOT_TRACE_DIR=traces

# Real flight search for ANY route (Amadeus Self-Service, free tier).
# Get keys at https://developers.amadeus.com → Self-Service → create an app.
# Without these, flight search falls back to the bundled offline inventory.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_HOSTNAME=test    # "test" (free) or "production"

# Real cached fares for any route (Travelpayouts/Aviasales, free token).
# Sign up at https://www.travelpayouts.com → Profile → API token.
TRAVELPAYOUTS_TOKEN=

# Flight source switch: "auto" tries every available real source in priority order
# (amadeus → travelpayouts → fast-flights → opensky), then inventory, then a
# labeled estimate. Specific value forces one ("opensky"/"travelpayouts"/...).
# Unset = offline (inventory/estimate only). fast-flights needs the [flights] extra.
COPILOT_FLIGHT_SOURCE=auto

# Telegram bot — the concierge on a real chat channel. Get a token from @BotFather.
TELEGRAM_BOT_TOKEN=
